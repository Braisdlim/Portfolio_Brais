---
// Contact Section Component
---

<section id="contacto" class="contact-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title" data-translate="contact-title">Contacto</h2>
      <p class="section-description" data-translate="contact-text">
        ¿Te ha gustado mi perfil? Hablemos sobre cómo puedo aportar valor a tu
        proyecto.
      </p>
    </div>

    <div class="contact-grid">
      <!-- Email Card -->
      <a href="mailto:braisdlim.tw@gmail.com" class="contact-card email-card">
        <div class="card-content">
          <div class="icon-wrapper email-icon">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="text-content">
            <h3 class="card-title">Email</h3>
            <p class="card-value">braisdlim.tw@gmail.com</p>
            <span class="card-action" data-translate="send-email"
              >Enviar mensaje &rarr;</span
            >
          </div>
        </div>
        <div class="card-bg-glow"></div>
      </a>

      <!-- LinkedIn Card -->
      <a
        href="https://www.linkedin.com/in/brais-de-la-iglesia-mart%C3%ADnez-448250349/"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card linkedin-card"
      >
        <div class="card-content">
          <div class="icon-wrapper linkedin-icon">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </div>
          <div class="text-content">
            <h3 class="card-title">LinkedIn</h3>
            <p class="card-value">Brais de la Iglesia</p>
            <span class="card-action" data-translate="connect-linkedin"
              >Conectar &rarr;</span
            >
          </div>
        </div>
        <div class="card-bg-glow"></div>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 6rem 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    position: relative;
    overflow: hidden;
  }

  .contact-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(
        circle at 20% 20%,
        rgba(0, 245, 255, 0.08) 0%,
        transparent 40%
      ),
      radial-gradient(
        circle at 80% 80%,
        rgba(217, 70, 239, 0.08) 0%,
        transparent 40%
      ),
      linear-gradient(
        0deg,
        transparent 0%,
        rgba(255, 255, 255, 0.02) 50%,
        transparent 100%
      );
    pointer-events: none;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(
      135deg,
      var(--accent-cyan),
      var(--accent-purple)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }

  .section-description {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Usamos #contacto para aumentar la especificidad */
  #contacto .contact-card {
    position: relative;
    display: block;
    text-decoration: none;
    background: rgba(30, 41, 59, 0.4); /* Fondo más visible */
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.5rem;
    padding: 2.5rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(12px);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  #contacto .contact-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    background: rgba(30, 41, 59, 0.6);
  }

  .card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .icon-wrapper {
    width: 4rem;
    height: 4rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .email-icon {
    background: rgba(0, 245, 255, 0.1);
    color: var(--accent-cyan);
  }

  .linkedin-icon {
    background: rgba(217, 70, 239, 0.1);
    color: var(--accent-purple);
  }

  #contacto .contact-card:hover .email-icon {
    background: var(--accent-cyan);
    color: #000;
    box-shadow: 0 0 20px rgba(0, 245, 255, 0.4);
  }

  #contacto .contact-card:hover .linkedin-icon {
    background: var(--accent-purple);
    color: #fff;
    box-shadow: 0 0 20px rgba(217, 70, 239, 0.4);
  }

  .text-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .card-value {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0;
    transition: color 0.3s ease;
  }

  #contacto .contact-card:hover .card-value {
    color: var(--text-primary);
  }

  .card-action {
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }

  .email-card .card-action {
    color: var(--accent-cyan);
  }
  .linkedin-card .card-action {
    color: var(--accent-purple);
  }

  #contacto .contact-card:hover .card-action {
    opacity: 1;
    transform: translateY(0);
  }

  .card-bg-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 1;
  }

  .email-card .card-bg-glow {
    background: radial-gradient(
      circle at top right,
      rgba(0, 245, 255, 0.15),
      transparent 60%
    );
  }

  .linkedin-card .card-bg-glow {
    background: radial-gradient(
      circle at top right,
      rgba(217, 70, 239, 0.15),
      transparent 60%
    );
  }

  #contacto .contact-card:hover .card-bg-glow {
    opacity: 1;
  }

  /* Light Mode Styles */
  html.light-mode .contact-section {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  }

  html.light-mode .contact-section::before {
    background-image: radial-gradient(
        circle at 20% 20%,
        rgba(37, 99, 235, 0.08) 0%,
        transparent 40%
      ),
      radial-gradient(
        circle at 80% 80%,
        rgba(124, 58, 237, 0.08) 0%,
        transparent 40%
      );
  }

  html.light-mode .section-title {
    background: linear-gradient(
      135deg,
      var(--accent-blue),
      var(--accent-purple)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html.light-mode #contacto .contact-card {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  html.light-mode #contacto .contact-card:hover {
    background: #ffffff;
    border-color: var(--accent-blue);
    box-shadow: 0 20px 40px rgba(37, 99, 235, 0.15);
  }

  html.light-mode .email-icon {
    background: rgba(37, 99, 235, 0.1);
    color: var(--accent-blue);
  }

  html.light-mode .linkedin-icon {
    background: rgba(124, 58, 237, 0.1);
    color: var(--accent-purple);
  }

  html.light-mode #contacto .contact-card:hover .email-icon {
    background: var(--accent-blue);
    color: #fff;
  }

  html.light-mode #contacto .contact-card:hover .linkedin-icon {
    background: var(--accent-purple);
    color: #fff;
  }

  html.light-mode .card-title {
    color: var(--text-primary);
  }

  html.light-mode .card-value {
    color: var(--text-muted);
  }

  html.light-mode #contacto .contact-card:hover .card-value {
    color: var(--text-primary);
  }

  html.light-mode .email-card .card-action {
    color: var(--accent-blue);
  }
  html.light-mode .linkedin-card .card-action {
    color: var(--accent-purple);
  }
</style>
